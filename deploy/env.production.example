# Copier ce fichier dans D:\Claude\Projet Omaya\.env sur le serveur
# et ajuster les valeurs sensibles.

# App
APP_NAME=ERP Omaya
APP_VERSION=1.0.0
DEBUG=False

# CORS : domaines autorisés (séparés par virgules, sans espaces)
CORS_ORIGINS=https://sos.groupe-exo.omaya.fr

# HFSQL Server (bridge local)
HFSQL_HOST=192.168.1.201
HFSQL_PORT=4901
HFSQL_USER=admin
HFSQL_PASSWORD=REMPLACER
HFSQL_DB_PASSWORD=REMPLACER
HFSQL_DRIVER=HFSQL
HFSQL_BRIDGE_PATH=D:\Claude\Projet Omaya\bridge\Dll_ODBC.exe

# Bases de données
HFSQL_DB_ADV=Bdd_Omaya_ADV
HFSQL_DB_DIVERS=Bdd_Omaya_Divers
HFSQL_DB_RECRUTEMENT=Bdd_Omaya_Recrutement
HFSQL_DB_RH=Bdd_Omaya_RH
HFSQL_DB_SCOOL=Bdd_Omaya_Scool
HFSQL_DB_TICKET=Bdd_Omaya_Ticket
HFSQL_DB_TICKET_BO=Bdd_Omaya_Ticket_BO
HFSQL_DB_TICKET_DPAE=Bdd_Omaya_Ticket_DPAE
HFSQL_DB_TICKET_RH=Bdd_Omaya_Ticket_RH
HFSQL_DB_ULEASE=ulease

# API Keys
SMS_API_KEY=REMPLACER
SMS_API_URL=api-new.smsmode.com
GOOGLE_MAPS_API_KEY=REMPLACER
GOOGLE_MAPS_SECRET=REMPLACER

# FTP
FTP_HOST=192.168.1.202
FTP_USER=OMAYA
FTP_PASSWORD=REMPLACER

# Chemins fichiers
DOCS_BASE_PATH=D:\Profil\Documents\Mes_Docs_OMAYA
DOCS_URL=https://interne.omaya.fr/

# Emails de service
MAIL_SUPPORT=intranet@omaya.fr
MAIL_TECH=a.loudieux@exosphere.fr
MAIL_TABLETTE=tablettes@omaya.fr
MAIL_RESP_RH=marie@exosphere.fr
MAIL_RH=rh@exosphere.fr
MAIL_DPAE=due@exosphere.fr
MAIL_RESP_BO=yamina@exosphere.fr
MAIL_BO=bo@exosphere.fr
MAIL_RESP_JURISTE=responsable@polejuristes.fr
MAIL_JURISTE_1=adm1@polejuristes.fr
MAIL_JURISTE_2=adm2@polejuristes.fr

# SMTP
