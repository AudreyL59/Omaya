# App
APP_NAME=ERP Omaya
APP_VERSION=1.0.0
DEBUG=True

# HFSQL Server
HFSQL_HOST=192.168.1.201
HFSQL_PORT=4901
HFSQL_USER=admin
HFSQL_PASSWORD=
HFSQL_DB_PASSWORD=

# PostgreSQL (cible migration HFSQL -> PG)
# Bascule progressive : ADM est deja sur PG pour les nouvelles pages (Registre RH...).
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=erp_db
PG_USER=erp_user
PG_PASSWORD=
PG_POOL_MAX=10
# Pour pointer vers un PG distant en dev sans toucher PG_HOST (.env partage) :
# PG_HOST_TEST=192.168.1.x

# HFSQL Bridge (exécutable WinDev)
HFSQL_BRIDGE_PATH=D:\Claude\Projet Omaya\bridge\hfsql_bridge.exe

# Bases de données
HFSQL_DB_ADV=Bdd_Omaya_ADV
HFSQL_DB_DIVERS=Bdd_Omaya_Divers
HFSQL_DB_RECRUTEMENT=Bdd_Omaya_Recrutement
HFSQL_DB_RH=Bdd_Omaya_RH
HFSQL_DB_SCOOL=Bdd_Omaya_Scool
HFSQL_DB_TICKET=Bdd_Omaya_Ticket
HFSQL_DB_TICKET_BO=Bdd_Omaya_Ticket_BO
HFSQL_DB_TICKET_DPAE=Bdd_Omaya_Ticket_DPAE
HFSQL_DB_TICKET_RH=Bdd_Omaya_Ticket_RH
HFSQL_DB_ULEASE=ulease

# API Keys
SMS_API_KEY=
SMS_API_URL=api-new.smsmode.com
GOOGLE_MAPS_API_KEY=
